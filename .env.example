# Mission Control — configuration.
#
# Copy to `.env` and edit. Every value has a sensible default (see config.py),
# so an empty .env works out of the box for the current user. `.env` is
# gitignored — never commit real values.
#
# The server reads these from the process environment. If you use a process
# manager that doesn't load .env automatically, `export` them or use the
# systemd unit's EnvironmentFile= (see mission-control.service.example).

# ---------------------------------------------------------------------------
# Server bind
# ---------------------------------------------------------------------------
# Host the web server binds to. Defaults to loopback (safe). Set to a private
# tailnet / LAN IP to reach it from other devices — do NOT bind to 0.0.0.0 on
# an untrusted network (there is no auth layer; it's meant for a private host).
MC_HOST=127.0.0.1
MC_PORT=51763

# ---------------------------------------------------------------------------
# Data roots
# ---------------------------------------------------------------------------
# Base home used to derive defaults below. Defaults to the running user's home.
# MC_HOME=/home/you

# A Hermes install (https://github.com — the open-source agent framework this
# dashboard surfaces). Data-backed tabs read SQLite DBs under here. Leave unset
# to default to $MC_HOME/.hermes; point elsewhere to use a different install.
# HERMES_HOME=/home/you/.hermes

# Markdown study vault the dashboard indexes (Library / Knowledge / search).
# SUBJECTS_DIR=/home/you/subjects

# Where Scholar research markdown is written/read.
# RESEARCH_DIR=/home/you/research

# Obsidian vault surfaced through the Obsidian / Brain tabs.
# OBSIDIAN_VAULT=/path/to/Obsidian/Vault

# Dashboard-local knowledge graph DB (additive; created on demand).
# KNOWLEDGE_DB=/home/you/dashboard/memory_core.db

# ---------------------------------------------------------------------------
# Agent invocation (optional — only if you run a Hermes install)
# ---------------------------------------------------------------------------
# Python interpreter used to shell out to `hermes` agent oneshots. Must be the
# Hermes venv (it imports hermes_cli), NOT this project's .venv.
# HERMES_PYTHON=/home/you/.hermes/hermes-agent/venv/bin/python

# ---------------------------------------------------------------------------
# Optional integrations (degrade silently if absent)
# ---------------------------------------------------------------------------
# KOKORO_TTS_DIR=/home/you/voice/tts     # local Kokoro TTS for read-aloud
# KOKORO_VOICE=af_heart

# ---------------------------------------------------------------------------
# Personalization
# ---------------------------------------------------------------------------
# Display name surfaced in the greeting card and chat sender label.
# MC_USER_NAME=Student

# Optional Discord routing for agents (comma-separated agent:channel-id pairs).
# Leave unset to skip Discord; chat still works in-app.
# MC_DISCORD_CHANNELS=vault:111,scholar:222,quizmaster:333,planner:444,dev:555
